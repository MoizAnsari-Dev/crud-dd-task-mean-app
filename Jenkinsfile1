pipeline {
    agent any

    environment {
        DOCKERHUB_USERNAME = 'moizaman'
        DOCKERHUB_CREDENTIALS_ID = 'dockerhub-credentials'
        GITHUB_CREDENTIALS_ID = 'github-credentials' // You will need to add this to Jenkins credentials
        NAMESPACE = 'mean-app'
        IMAGE_TAG = "build-${BUILD_NUMBER}" // Use dynamic build tags for GitOps
    }

    stages {
        stage('Checkout Code') {
            steps {
                git branch: 'main', url: 'https://github.com/MoizAnsari-Dev/crud-dd-task-mean-app.git'
            }
        }

        stage('Build Docker Images') {
            steps {
                script {
                    echo "Building Backend Image from Dockerfile..."
                    sh "docker build -t ${DOCKERHUB_USERNAME}/mean-task-backend:${IMAGE_TAG} ./backend"

                    echo "Building Frontend Image from Dockerfile..."
                    sh "docker build -t ${DOCKERHUB_USERNAME}/mean-task-frontend:${IMAGE_TAG} ./frontend"

                    echo "Building Auth Backend Image from Dockerfile..."
                    sh "docker build -t ${DOCKERHUB_USERNAME}/mean-task-auth-backend:${IMAGE_TAG} ./auth-backend"
                }
            }
        }

        stage('Docker Login') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: env.DOCKERHUB_CREDENTIALS_ID,
                    usernameVariable: 'DOCKER_USER',
                    passwordVariable: 'DOCKER_PASS'
                )]) {
                    sh 'echo $DOCKER_PASS | docker login -u $DOCKER_USER --password-stdin'
                }
            }
        }

        stage('Push to Docker Hub') {
            steps {
                script {
                    echo "Pushing images to Docker Hub with tag ${IMAGE_TAG}..."
                    sh "docker push ${DOCKERHUB_USERNAME}/mean-task-backend:${IMAGE_TAG}"
                    sh "docker push ${DOCKERHUB_USERNAME}/mean-task-frontend:${IMAGE_TAG}"
                    sh "docker push ${DOCKERHUB_USERNAME}/mean-task-auth-backend:${IMAGE_TAG}"
                }
            }
        }

        stage('Update GitOps Manifests') {
            steps {
                script {
                    echo "Updating Kubernetes manifests for ArgoCD..."
                    // Update the image tags in the K8s manifests using sed
                    sh "sed -i 's|moizaman/mean-task-backend:.*|moizaman/mean-task-backend:${IMAGE_TAG}|g' k8s/backend.yaml"
                    sh "sed -i 's|moizaman/mean-task-frontend:.*|moizaman/mean-task-frontend:${IMAGE_TAG}|g' k8s/frontend.yaml"
                    sh "sed -i 's|moizaman/mean-task-auth-backend:.*|moizaman/mean-task-auth-backend:${IMAGE_TAG}|g' k8s/auth-backend.yaml"

                    // Commit and push changes back to Git so ArgoCD syncs them
                    withCredentials([gitUsernamePassword(credentialsId: env.GITHUB_CREDENTIALS_ID, gitToolName: 'Default')]) {
                        sh """
                            git config user.email "jenkins-ci@example.com"
                            git config user.name "Jenkins GitOps Bot"
                            git remote set-url origin https://github.com/MoizAnsari-Dev/crud-dd-task-mean-app.git
                            git add k8s/backend.yaml k8s/frontend.yaml k8s/auth-backend.yaml
                            git commit -m "Bump image tags to ${IMAGE_TAG} [skip ci]" || echo "No changes to commit"
                            git push origin HEAD:main
                        """
                    }
                }
            }
        }
    }

    post {
        success {
            echo "CI pipeline completed! ArgoCD will now detect the changes in GitHub and deploy them to the cluster."
        }
        failure {
            echo "Pipeline failed. Check Jenkins logs for details."
        }
        always {
            sh "docker logout || true"
            cleanWs()
        }
    }
}
